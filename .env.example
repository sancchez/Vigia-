# Copia este archivo como .env y completa los valores reales. Nunca commitees .env.

# --- Claude / Anthropic ---
ANTHROPIC_API_KEY=

# --- Base de datos ---
DATABASE_URL=sqlite:///./ciberseguridad.db
SUPABASE_URL=
SUPABASE_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Auth (multi-tenant, ver auth/jwt_auth.py) ---
# Genera uno real para cualquier entorno que no sea tu laptop de desarrollo:
# py -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Pagos (Wompi, sandbox hasta tener una cuenta comercial real) ---
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# --- Herramientas externas (se completan a medida que se integren en tools/) ---
GOOGLE_SAFE_BROWSING_API_KEY=
