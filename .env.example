# Copia este archivo como .env y completa los valores reales. Nunca commitees .env.

# --- LLM (agents/_llm.py) ---
# Dos proveedores soportados: Anthropic (Claude) y OpenAI. Configura UNA de
# las dos keys de abajo -- VIGIA_LLM_PROVIDER es opcional, solo hace falta
# si tenés AMBAS keys y querés forzar cuál se usa (ver docs/despliegue.md).
ANTHROPIC_API_KEY=
# Si no hay ninguna key configurada, agents/_llm.py usa la CLI de Claude Code
# (claude -p) como fallback de desarrollo/demo -- SOLO funciona en una
# máquina con Claude Code instalado y con sesión iniciada, NUNCA en un host
# desplegado (Railway/Render). Timeout configurable, la latencia real varía:
VIGIA_CLAUDE_CLI_TIMEOUT=300

# Alternativa barata para producción real (no tiene fallback de CLI):
OPENAI_API_KEY=
# VIGIA_LLM_PROVIDER=openai
# VIGIA_OPENAI_MODEL=gpt-5.4-mini

# --- Base de datos ---
DATABASE_URL=sqlite:///./ciberseguridad.db
SUPABASE_URL=
SUPABASE_KEY=

# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Auth (multi-tenant, ver auth/jwt_auth.py) ---
# Genera uno real para cualquier entorno que no sea tu laptop de desarrollo:
# py -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# --- Pagos (Wompi, sandbox hasta tener una cuenta comercial real) ---
WOMPI_PUBLIC_KEY=
WOMPI_PRIVATE_KEY=
WOMPI_EVENTS_SECRET=

# --- Herramientas externas (se completan a medida que se integren en tools/) ---
GOOGLE_SAFE_BROWSING_API_KEY=

# --- Escaneo recurrente (api/scheduler.py) ---
VIGIA_SCAN_INTERVAL_HOURS=6
